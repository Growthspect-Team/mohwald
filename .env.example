# Konfigurace pro odesílání emailů

# Váš Gmail účet (celá adresa)
GMAIL_USER=vas.email@gmail.com

# Heslo aplikace (App Password) - NIKDY nepoužívejte vaše hlavní heslo k emailu!
# Vygenerujte si ho zde: https://myaccount.google.com/apppasswords
# Návod: Jděte do Zabezpečení -> Dvoufázové ověření -> Hesla aplikací
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Poznámka: Tento soubor přejmenujte na .env nebo nastavte tyto proměnné prostředí ve Vercel (Project Settings -> Environment Variables)
